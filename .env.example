# Copy this file to `.env` (same folder as earthquake_agent.py) and fill in.

# Get a free key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-key-here

# Any Gemini model that supports text generation. Flash-Lite is cheapest.
GEMINI_MODEL=gemini-2.5-flash-lite

# Seconds to sleep before each LLM call (free tier is 15 RPM on Flash-Lite).
# Bump this to 10 if you hit rate-limit errors.
THROTTLE_SECONDS=4
